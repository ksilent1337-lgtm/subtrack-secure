rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == "admin";
    }

    function allowedUserCreateKeys() {
      return request.resource.data.keys().hasOnly([
        "displayName",
        "email",
        "telegramUsername",
        "theme",
        "createdAt",
        "updatedAt"
      ]);
    }

    function allowedUserUpdateKeys() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "displayName",
        "telegramUsername",
        "theme",
        "updatedAt"
      ]);
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && allowedUserCreateKeys()
        && request.resource.data.email == request.auth.token.email;

      allow update: if (isOwner(uid) && allowedUserUpdateKeys()) || isAdmin();

      allow delete: if false;

      match /subscriptions/{subscriptionId} {
        allow read, create, update, delete: if isOwner(uid) || isAdmin();
      }
    }

    match /premiumRequests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "telegram",
          "plan",
          "status",
          "createdAt",
          "approvedBy"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "pending";

      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
